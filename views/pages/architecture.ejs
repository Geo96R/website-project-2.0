<!-- ===== ARCHITECTURE ===== -->
<section id="architecture" style="padding-top:80px;">
  <div class="sh">
    <div class="si-idx">01</div>
    <div>
      <div class="s-tag">Experience in Production Environments</div>
      <h2 class="s-title">High-Density Container<br>Infrastructure</h2>
      <p class="s-desc">
        Hosts running 100&ndash;200 isolated application containers behind per-tenant
        NGINX reverse proxy configuration. SSL lifecycle, PHP-FPM pool tuning, and
        container orchestration are fully automated across a fleet of 20+ servers
        spanning multiple VPS providers.
      </p>
    </div>
  </div>

